    "Smart auto-surface is off. Click to turn back on.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Intelligentes Auto-Anzeigen ist deaktiviert. Klicken, um es wieder einzuschalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La aparición automática inteligente está desactivada. Haz clic para volver a activarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'affichage automatique intelligent est désactivé. Cliquez pour le réactiver."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tampilan otomatis cerdas nonaktif. Klik untuk mengaktifkan kembali."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La visualizzazione automatica intelligente è disattivata. Fai clic per riattivarla."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スマート自動表示はオフです。クリックして再度オンにします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스마트 자동 표시가 꺼져 있습니다. 클릭하여 다시 켜세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Slim automatisch weergeven is uitgeschakeld. Klik om het weer in te schakelen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Inteligentne automatyczne pojawianie się jest wyłączone. Kliknij, aby włączyć ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A exibição automática inteligente está desativada. Clique para reativar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Умное автопоявление отключено. Нажмите, чтобы включить снова."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Smart automatisk visning är av. Klicka för att slå på igen."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Akıllı otomatik gösterim kapalı. Tekrar açmak için tıklayın."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tự động hiện thông minh đang tắt. Nhấp để bật lại."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智能自动显示已关闭。点击重新开启。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "智慧自動顯示已關閉。點選重新開啟。"
          }
        }
      }
    },
    "Smart auto-surface is on — switching to the app a reference was pinned from brings it forward automatically. Click to turn off.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Intelligentes Auto-Anzeigen ist aktiviert — beim Wechsel zur App, aus der eine Referenz angeheftet wurde, wird sie automatisch nach vorne gebracht. Klicken zum Ausschalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La aparición automática inteligente está activada — cambiar a la app desde la que se fijó una referencia la trae automáticamente al frente. Haz clic para desactivarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'affichage automatique intelligent est activé — passer à l'application depuis laquelle une référence a été épinglée la ramène automatiquement au premier plan. Cliquez pour désactiver."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tampilan otomatis cerdas aktif — beralih ke aplikasi tempat referensi disematkan akan membawanya ke depan secara otomatis. Klik untuk menonaktifkan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La visualizzazione automatica intelligente è attiva — passare all'app da cui è stato fissato un riferimento lo porta automaticamente in primo piano. Fai clic per disattivarla."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スマート自動表示はオンです — 参照が固定されたAppに切り替えると自動的に前面に表示されます。クリックしてオフにします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스마트 자동 표시가 켜져 있습니다 — 참조가 고정된 앱으로 전환하면 자동으로 앞으로 가져옵니다. 클릭하여 끄세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Slim automatisch weergeven is ingeschakeld — overschakelen naar de app waarvan een referentie was vastgepind, brengt deze automatisch naar voren. Klik om uit te schakelen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Inteligentne automatyczne pojawianie się jest włączone — przełączenie na aplikację, z której przypięto odwołanie, automatycznie wysuwa je na wierzch. Kliknij, aby wyłączyć."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A exibição automática inteligente está ativada — mudar para o aplicativo do qual uma referência foi fixada a traz para frente automaticamente. Clique para desativar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Умное автопоявление включено — переключение на приложение, из которого была закреплена ссылка, автоматически выводит её на передний план. Нажмите, чтобы выключить."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Smart automatisk visning är på — att växla till appen som en referens fästes från tar automatiskt fram den. Klicka för att stänga av."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Akıllı otomatik gösterim açık — bir referansın sabitlendiği uygulamaya geçmek onu otomatik olarak öne getirir. Kapatmak için tıklayın."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tự động hiện thông minh đang bật — chuyển sang ứng dụng mà tham chiếu được ghim từ đó sẽ tự động đưa nó lên trước. Nhấp để tắt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智能自动显示已开启——切换回引用被置顶时所在的应用会自动将其带到前台。点击关闭。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "智慧自動顯示已開啟——切換回參照被釘選時所在的應用程式會自動將其帶到前景。點選關閉。"
          }
        }
      }
    },
