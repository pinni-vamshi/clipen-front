    "Copied %lld of %lld — copy the rest to continue.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld von %2$lld kopiert — kopiere den Rest, um fortzufahren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Copied %1$lld of %2$lld — copy the rest to continue."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld de %2$lld copiados — copia el resto para continuar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld sur %2$lld copiés — copiez le reste pour continuer."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld dari %2$lld disalin — salin sisanya untuk melanjutkan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld di %2$lld copiati — copia il resto per continuare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%2$lld件中%1$lld件コピー済み — 続けるには残りをコピーしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%2$lld개 중 %1$lld개 복사됨 — 계속하려면 나머지를 복사하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld van %2$lld gekopieerd — kopieer de rest om door te gaan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Skopiowano %1$lld z %2$lld — skopiuj resztę, aby kontynuować."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld de %2$lld copiados — copie o restante para continuar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Скопировано %1$lld из %2$lld — скопируйте остальное, чтобы продолжить."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld av %2$lld kopierade — kopiera resten för att fortsätta."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%2$lld öğeden %1$lld tanesi kopyalandı — devam etmek için kalanını kopyalayın."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đã sao chép %1$lld trong %2$lld — sao chép phần còn lại để tiếp tục."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已复制 %2$lld 项中的 %1$lld 项——复制其余部分以继续。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已複製 %2$lld 項中的 %1$lld 項——複製其餘部分以繼續。"
          }
        }
      }
    },
