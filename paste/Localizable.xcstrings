    "This will erase all clipboard history, settings, and saved data. The app will quit so changes take effect on next launch.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden der gesamte Zwischenablageverlauf, alle Einstellungen und gespeicherten Daten gelöscht. Die App wird beendet, damit die Änderungen beim nächsten Start wirksam werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto borrará todo el historial del portapapeles, los ajustes y los datos guardados. La app se cerrará para que los cambios surtan efecto en el próximo inicio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela effacera tout l'historique du presse-papiers, les réglages et les données enregistrées. L'application se fermera pour que les modifications prennent effet au prochain lancement."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini akan menghapus semua riwayat clipboard, pengaturan, dan data tersimpan. Aplikasi akan keluar agar perubahan berlaku saat diluncurkan berikutnya."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo cancellerà tutta la cronologia degli appunti, le impostazioni e i dati salvati. L'app si chiuderà affinché le modifiche abbiano effetto al prossimo avvio."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これにより、クリップボード履歴、設定、保存データがすべて消去されます。次回起動時に変更を反映させるためAppは終了します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 작업은 모든 클립보드 기록, 설정 및 저장된 데이터를 지웁니다. 변경 사항을 다음 실행 시 적용하기 위해 앱이 종료됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hierdoor worden alle klembordgeschiedenis, instellingen en opgeslagen gegevens gewist. De app wordt afgesloten zodat de wijzigingen bij de volgende start van kracht worden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spowoduje to usunięcie całej historii schowka, ustawień i zapisanych danych. Aplikacja zostanie zamknięta, aby zmiany zaczęły obowiązywać przy następnym uruchomieniu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso apagará todo o histórico da área de transferência, configurações e dados salvos. O aplicativo será encerrado para que as alterações tenham efeito na próxima abertura."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это сотрёт всю историю буфера обмена, настройки и сохранённые данные. Приложение завершит работу, чтобы изменения вступили в силу при следующем запуске."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Detta raderar all urklippshistorik, inställningar och sparad data. Appen avslutas så att ändringarna träder i kraft vid nästa start."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu, tüm pano geçmişini, ayarları ve kaydedilmiş verileri silecektir. Değişikliklerin bir sonraki başlatmada etkili olması için uygulama kapanacaktır."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thao tác này sẽ xóa toàn bộ lịch sử clipboard, cài đặt và dữ liệu đã lưu. Ứng dụng sẽ thoát để các thay đổi có hiệu lực vào lần khởi chạy tiếp theo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将清除所有剪贴板历史记录、设置和已保存的数据。应用将退出，以便更改在下次启动时生效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這將清除所有剪貼簿歷史記錄、設定和已儲存的資料。應用程式將結束，以便變更在下次啟動時生效。"
          }
        }
      }
    },
