    "Double-tap Space on the highlighted item.\nSends it to the Reference panel — the popup closes, the preview stays.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Doppeltippe die Leertaste auf dem hervorgehobenen Element.\nSendet es an das Referenzpanel — das Popup schließt sich, die Vorschau bleibt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca dos veces la barra espaciadora en el elemento resaltado.\nLo envía al panel de referencia — la ventana se cierra, la vista previa permanece."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Double-tapez sur Espace sur l'élément en surbrillance.\nL'envoie au panneau de référence — la fenêtre se ferme, l'aperçu reste."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ketuk dua kali Spasi pada item yang disorot.\nMengirimkannya ke panel referensi — popup tertutup, pratinjau tetap ada."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca due volte Spazio sull'elemento evidenziato.\nLo invia al pannello di riferimento — il popup si chiude, l'anteprima rimane."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ハイライトされた項目でスペースキーをダブルタップします。\n参照パネルに送られます。ポップアップは閉じますが、プレビューは残ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "강조된 항목에서 스페이스바를 두 번 누르세요.\n참조 패널로 전송됩니다 — 팝업은 닫히지만 미리보기는 유지됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dubbeltik op spatie op het gemarkeerde item.\nStuurt het naar het referentiepaneel — de pop-up sluit, het voorbeeld blijft."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Naciśnij spację dwukrotnie na wyróżnionym elemencie.\nWysyła go do panelu odwołań — wyskakujące okno się zamyka, podgląd pozostaje."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque duas vezes em Espaço no item destacado.\nEnvia-o para o painel de referência — o pop-up fecha, a pré-visualização permanece."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дважды нажмите пробел на выделенном элементе.\nОтправляет его на панель ссылок — всплывающее окно закрывается, предпросмотр остаётся."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dubbeltryck på mellanslag på det markerade objektet.\nSkickar det till referenspanelen — popupen stängs, förhandsgranskningen finns kvar."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vurgulanan öğede Boşluk'a çift dokunun.\nOnu Referans paneline gönderir — açılır pencere kapanır, önizleme kalır."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhấn đúp phím Cách trên mục đang được đánh dấu.\nGửi nó đến bảng tham chiếu — cửa sổ bật lên đóng lại, bản xem trước vẫn còn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在高亮项目上双击空格键。\n将其发送到引用面板——弹出窗口关闭，预览保留。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在醒目提示項目上雙擊空格鍵。\n將其傳送到參照面板——彈出視窗關閉，預覽保留。"
          }
        }
      }
    },
