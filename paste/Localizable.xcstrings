    "No pinned reference belongs to the active app. Click to reopen — this will also link the reference to this app.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine angeheftete Referenz gehört zur aktiven App. Klicken zum erneuten Öffnen — dies verknüpft die Referenz auch mit dieser App."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ninguna referencia fijada pertenece a la app activa. Haz clic para volver a abrir — esto también vinculará la referencia a esta app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune référence épinglée n'appartient à l'application active. Cliquez pour rouvrir — cela liera aussi la référence à cette application."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak ada referensi yang disematkan milik aplikasi aktif. Klik untuk membuka lagi — ini juga akan menautkan referensi ke aplikasi ini."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun riferimento fissato appartiene all'app attiva. Fai clic per riaprire — questo collegherà anche il riferimento a questa app."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティブなAppに属する固定された参照はありません。クリックして再度開くと、この参照がこのAppにリンクされます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "활성 앱에 속하는 고정된 참조가 없습니다. 클릭하여 다시 열면 이 참조가 이 앱에 연결됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geen vastgepinde referentie behoort tot de actieve app. Klik om opnieuw te openen — dit koppelt de referentie ook aan deze app."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Żadne przypięte odwołanie nie należy do aktywnej aplikacji. Kliknij, aby otworzyć ponownie — to również połączy odwołanie z tą aplikacją."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhuma referência fixada pertence ao aplicativo ativo. Clique para reabrir — isso também vinculará a referência a este aplicativo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ни одна закреплённая ссылка не принадлежит активному приложению. Нажмите, чтобы открыть снова — это также свяжет ссылку с этим приложением."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen fäst referens tillhör den aktiva appen. Klicka för att öppna igen — detta kommer också att länka referensen till den här appen."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Etkin uygulamaya ait sabitlenmiş bir referans yok. Yeniden açmak için tıklayın — bu, referansı da bu uygulamaya bağlar."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không có tham chiếu đã ghim nào thuộc về ứng dụng đang hoạt động. Nhấp để mở lại — điều này cũng sẽ liên kết tham chiếu với ứng dụng này."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有已置顶的引用属于当前活动应用。点击重新打开——这也会将该引用关联到此应用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "沒有已釘選的參照屬於目前的使用中應用程式。點選以重新開啟——這也會將該參照關聯到此應用程式。"
          }
        }
      }
    },
