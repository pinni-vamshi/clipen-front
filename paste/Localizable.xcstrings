          }
        }
      }
    },
    "Close (opened via hold — ⌘ release won't close this)": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schließen (durch Halten geöffnet — Loslassen von ⌘ schließt dies nicht)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cerrar (abierto manteniendo pulsado — soltar ⌘ no lo cerrará)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fermer (ouvert par maintien — relâcher ⌘ ne fermera pas ceci)"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutup (dibuka dengan menahan — melepaskan ⌘ tidak akan menutup ini)"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chiudi (aperto tenendo premuto — rilasciare ⌘ non lo chiuderà)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "閉じる（長押しで開いたため、⌘を離しても閉じません）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "닫기(길게 눌러 열림 — ⌘를 떼도 닫히지 않음)"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sluiten (geopend door vasthouden — ⌘ loslaten sluit dit niet)"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zamknij (otwarto przytrzymaniem — puszczenie ⌘ tego nie zamknie)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fechar (aberto ao manter pressionado — soltar ⌘ não fechará isso)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Закрыть (открыто удержанием — отпускание ⌘ не закроет это)"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Stäng (öppnades genom att hålla in — att släppa ⌘ stänger inte detta)"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kapat (basılı tutarak açıldı — ⌘ bırakmak bunu kapatmaz)"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đóng (được mở bằng cách giữ — thả ⌘ sẽ không đóng cái này)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭（长按打开——松开 ⌘ 不会关闭此项）"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "關閉（長按開啟——放開 ⌘ 不會關閉此項）"
          }
        }
      }
    },
    "Close entire panel (all %lld references)": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gesamtes Panel schließen (alle %lld Referenzen)"
          }
        },
        "es": {
          "stringUnit": {
