    "Click into each box, select the text, and press ⌘C. Clipen will catch every copy automatically.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Klicke in jedes Feld, wähle den Text aus und drücke ⌘C. Clipen erfasst jede Kopie automatisch."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz clic en cada cuadro, selecciona el texto y pulsa ⌘C. Clipen capturará cada copia automáticamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliquez dans chaque zone, sélectionnez le texte et appuyez sur ⌘C. Clipen capture automatiquement chaque copie."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Klik ke setiap kotak, pilih teksnya, lalu tekan ⌘C. Clipen akan menangkap setiap salinan secara otomatis."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fai clic in ogni riquadro, seleziona il testo e premi ⌘C. Clipen catturerà automaticamente ogni copia."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各ボックスをクリックしてテキストを選択し、⌘Cを押してください。Clipenがすべてのコピーを自動的に取得します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "각 상자를 클릭하고 텍스트를 선택한 다음 ⌘C를 누르세요. Clipen이 모든 복사를 자동으로 캡처합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Klik in elk vak, selecteer de tekst en druk op ⌘C. Clipen vangt elke kopie automatisch op."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kliknij w każde pole, zaznacz tekst i naciśnij ⌘C. Clipen automatycznie przechwyci każdą kopię."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Clique em cada caixa, selecione o texto e pressione ⌘C. O Clipen capturará cada cópia automaticamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Щёлкните в каждом поле, выделите текст и нажмите ⌘C. Clipen автоматически перехватит каждую копию."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Klicka i varje ruta, markera texten och tryck på ⌘C. Clipen fångar automatiskt varje kopiering."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her kutuya tıklayın, metni seçin ve ⌘C tuşlarına basın. Clipen her kopyalamayı otomatik olarak yakalar."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhấp vào từng ô, chọn văn bản rồi nhấn ⌘C. Clipen sẽ tự động bắt mọi thao tác sao chép."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击每个方框，选中文本，然后按 ⌘C。Clipen 会自动捕获每一次复制。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點選每個方塊，選取文字，然後按 ⌘C。Clipen 會自動擷取每一次複製。"
          }
        }
      }
    },
