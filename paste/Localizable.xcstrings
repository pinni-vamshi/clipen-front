          "stringUnit": {
            "state": "translated",
            "value": "Premi ⌘V — tieni premuto ⌘ mentre il timer si riempie, e si aprirà il selettore Clipen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "⌘Vを押し、タイマーが満ちるまで⌘を押し続けるとClipenピッカーが開きます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "⌘V를 누르고 타이머가 찰 때까지 ⌘를 누른 채로 있으면 Clipen 선택기가 열립니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Druk op ⌘V — houd ⌘ ingedrukt terwijl de timer vult, en de Clipen-kiezer opent."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Naciśnij ⌘V — przytrzymaj ⌘, aż minutnik się wypełni, a otworzy się selektor Clipen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pressione ⌘V — mantenha ⌘ pressionado enquanto o temporizador se completa, e o seletor do Clipen abrirá."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите ⌘V — удерживайте ⌘, пока таймер заполняется, и откроется выбор Clipen."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryck på ⌘V — håll ⌘ intryckt medan timern fylls, så öppnas Clipen-väljaren."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "⌘V'ye basın — zamanlayıcı dolarken ⌘'yi basılı tutun, Clipen seçici açılacaktır."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhấn ⌘V — giữ ⌘ trong khi bộ đếm giờ đầy, bộ chọn Clipen sẽ mở ra."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按下 ⌘V——在计时器填满期间持续按住 ⌘，Clipen 选择器即会打开。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按下 ⌘V——在計時器填滿期間持續按住 ⌘，Clipen 選擇器即會開啟。"
          }
        }
      }
    },
