    "Clipen needs Accessibility access so\n⌘V can cycle your clipboard ring.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen benötigt Bedienungshilfen-Zugriff, damit\n⌘V durch deinen Clipboard-Ring wechseln kann."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen necesita acceso de Accesibilidad para que\n⌘V pueda recorrer tu historial del portapapeles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen a besoin de l'accès Accessibilité pour que\n⌘V puisse parcourir votre presse-papiers."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen memerlukan akses Aksesibilitas agar\n⌘V dapat menelusuri cincin clipboard Anda."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen richiede l'accesso Accessibilità affinché\n⌘V possa scorrere l'anello degli appunti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "⌘Vでクリップボードリングを切り替えるには\nClipenに「アクセシビリティ」の許可が必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "⌘V로 클립보드 링을 순환하려면\nClipen에 손쉬운 사용 권한이 필요합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen heeft toegankelijkheidstoegang nodig zodat\n⌘V door je klembordring kan bladeren."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen potrzebuje dostępu do ułatwień dostępu, aby\n⌘V mogło przełączać pierścień schowka."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Clipen precisa de acesso de Acessibilidade para que\n⌘V possa percorrer seu histórico de área de transferência."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen нужен доступ к специальным возможностям, чтобы\n⌘V мог переключать буфер обмена."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen behöver tillgänglighetsåtkomst så att\n⌘V kan bläddra i din urklippsring."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen'in ⌘V ile pano halkanızda gezinebilmesi için\nErişilebilirlik izni gerekiyor."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen cần quyền Trợ năng để\n⌘V có thể xoay vòng clipboard của bạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen 需要辅助功能权限，\n以便 ⌘V 可以循环切换剪贴板。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen 需要輔助使用權限，\n讓 ⌘V 可以循環切換剪貼簿。"
          }
        }
      }
    },
    "Clipen needs Accessibility permission to show the paste popup. History and double-click-to-paste still work.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen benötigt die Bedienungshilfen-Berechtigung, um das Einfüge-Popup anzuzeigen. Verlauf und Doppelklick-Einfügen funktionieren weiterhin."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen necesita permiso de Accesibilidad para mostrar la ventana de pegado. El historial y pegar con doble clic siguen funcionando."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen a besoin de l'autorisation Accessibilité pour afficher la fenêtre de collage. L'historique et le collage par double-clic fonctionnent toujours."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen memerlukan izin Aksesibilitas untuk menampilkan popup tempel. Riwayat dan klik dua kali untuk menempel tetap berfungsi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen richiede l'autorizzazione Accessibilità per mostrare il popup di incolla. Cronologia e incolla con doppio clic continuano a funzionare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "貼り付けポップアップを表示するには「アクセシビリティ」の許可が必要です。履歴とダブルクリックでの貼り付けは引き続き使用できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "붙여넣기 팝업을 표시하려면 손쉬운 사용 권한이 필요합니다. 기록과 더블클릭 붙여넣기는 계속 작동합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen heeft toegankelijkheidstoestemming nodig om de plak-pop-up te tonen. Geschiedenis en dubbelklikken om te plakken werken nog steeds."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen potrzebuje uprawnienia dostępności, aby wyświetlić wyskakujące okno wklejania. Historia i wklejanie dwukrotnym kliknięciem nadal działają."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Clipen precisa da permissão de Acessibilidade para mostrar o pop-up de colagem. O histórico e colar com clique duplo continuam funcionando."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для отображения всплывающего окна вставки Clipen нужно разрешение специальных возможностей. История и вставка двойным щелчком продолжают работать."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen behöver tillgänglighetsbehörighet för att visa inklistringsfönstret. Historik och dubbelklick för att klistra in fungerar fortfarande."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yapıştırma açılır penceresini göstermek için Clipen'in Erişilebilirlik iznine ihtiyacı var. Geçmiş ve çift tıklayarak yapıştırma yine de çalışır."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen cần quyền Trợ năng để hiển thị cửa sổ dán. Lịch sử và dán bằng cách nhấp đúp vẫn hoạt động."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen 需要辅助功能权限才能显示粘贴弹出窗口。历史记录和双击粘贴仍可正常使用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen 需要輔助使用權限才能顯示貼上彈出視窗。歷史記錄與雙擊貼上仍可正常使用。"
          }
        }
      }
    },
    "Clipen needs to restart to switch to %@.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen muss neu gestartet werden, um zu %@ zu wechseln."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen debe reiniciarse para cambiar a %@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen doit redémarrer pour passer à %@."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen perlu dimulai ulang untuk beralih ke %@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen deve riavviarsi per passare a %@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@に切り替えるにはClipenの再起動が必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@(으)로 전환하려면 Clipen을 다시 시작해야 합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen moet opnieuw worden gestart om over te schakelen naar %@."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen musi zostać uruchomiony ponownie, aby przełączyć się na %@."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Clipen precisa reiniciar para mudar para %@."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen нужно перезапустить, чтобы переключиться на %@."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen måste startas om för att byta till %@."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen'in %@ diline geçmesi için yeniden başlatılması gerekiyor."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen cần khởi động lại để chuyển sang %@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen 需要重启才能切换到 %@。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipen 需要重新啟動才能切換到 %@。"
          }
        }
      }
    },
