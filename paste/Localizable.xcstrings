    "Nice! Tap Continue to learn how to paste them back.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Super! Tippe auf „Weiter“, um zu erfahren, wie du sie wieder einfügst."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Genial! Toca Continuar para aprender a volver a pegarlos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Super ! Appuyez sur Continuer pour apprendre à les recoller."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Bagus! Ketuk Lanjutkan untuk mempelajari cara menempelkannya kembali."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Bene! Tocca Continua per scoprire come incollarli di nuovo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "いいですね！「続ける」をタップして貼り付け方法を確認しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "좋습니다! 계속을 눌러 다시 붙여넣는 방법을 알아보세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Mooi! Tik op Doorgaan om te leren hoe je ze terugplakt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Świetnie! Dotknij Kontynuuj, aby dowiedzieć się, jak je wkleić z powrotem."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ótimo! Toque em Continuar para aprender a colá-los de volta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отлично! Нажмите «Продолжить», чтобы узнать, как вставить их обратно."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Snyggt! Tryck på Fortsätt för att lära dig hur du klistrar in dem igen."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Harika! Nasıl geri yapıştıracağınızı öğrenmek için Devam et'e dokunun."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tuyệt! Nhấn Tiếp tục để tìm hiểu cách dán chúng trở lại."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "太棒了！点击「继续」了解如何将它们粘贴回去。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "太棒了！點選「繼續」了解如何將它們貼回去。"
