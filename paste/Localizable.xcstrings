    "How long a remembered position stays valid before reopening starts at the top again": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie lange eine gemerkte Position gültig bleibt, bevor beim erneuten Öffnen wieder oben begonnen wird"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuánto tiempo sigue siendo válida una posición recordada antes de que reabrir vuelva a empezar arriba"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Durée pendant laquelle une position mémorisée reste valide avant que la réouverture ne recommence en haut"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Berapa lama posisi yang diingat tetap berlaku sebelum membuka ulang dimulai dari atas lagi"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per quanto tempo una posizione memorizzata resta valida prima che la riapertura ricominci dall'alto"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "記憶した位置が有効な時間。これを過ぎると再度開いたときに先頭から始まります"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기억된 위치가 유효한 시간으로, 이 시간이 지나면 다시 열 때 맨 위부터 시작됩니다"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoe lang een onthouden positie geldig blijft voordat opnieuw openen weer bovenaan begint"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jak długo zapamiętana pozycja pozostaje ważna, zanim ponowne otwarcie zacznie się znowu od góry"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Por quanto tempo uma posição lembrada permanece válida antes de reabrir do topo novamente"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Как долго запомненная позиция остаётся действительной, прежде чем при повторном открытии список снова начнётся сверху"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Hur länge en ihågkommen position förblir giltig innan återöppning börjar överst igen"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yeniden açıldığında en baştan başlamadan önce hatırlanan konumun ne kadar süre geçerli kalacağı"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vị trí đã ghi nhớ còn hiệu lực trong bao lâu trước khi mở lại bắt đầu từ đầu"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "记住的位置在重新打开时保持有效的时长，超时后将从顶部重新开始"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "記住的位置在重新開啟時保持有效的時間長度，超時後將從頂部重新開始"
          }
        }
      }
    },
    "How long the popup sits idle before it auto-dismisses": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie lange das Popup untätig bleibt, bevor es sich automatisch schließt"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuánto tiempo permanece inactiva la ventana antes de cerrarse automáticamente"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Durée d'inactivité de la fenêtre avant qu'elle ne se ferme automatiquement"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Berapa lama popup diam sebelum otomatis tertutup"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per quanto tempo il popup resta inattivo prima di chiudersi automaticamente"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動的に閉じるまでポップアップが操作されずに待機する時間"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "팝업이 자동으로 닫히기 전 대기하는 시간"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoe lang de pop-up inactief blijft voordat deze automatisch sluit"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jak długo wyskakujące okno pozostaje bezczynne, zanim się automatycznie zamknie"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Por quanto tempo o pop-up fica inativo antes de fechar automaticamente"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Как долго всплывающее окно остаётся бездействующим перед автоматическим закрытием"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Hur länge popupen är inaktiv innan den stängs automatiskt"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Açılır pencerenin otomatik kapanmadan önce ne kadar süre boşta kalacağı"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cửa sổ bật lên sẽ ở trạng thái chờ trong bao lâu trước khi tự động đóng"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "弹出窗口在自动关闭前保持空闲的时长"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "彈出視窗在自動關閉前保持閒置的時間長度"
          }
        }
      }
    },
