          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zamknij cały panel (wszystkie %lld odwołania)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fechar todo o painel (todas as %lld referências)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Закрыть всю панель (все ссылки: %lld)"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Stäng hela panelen (alla %lld referenser)"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tüm paneli kapat (%lld referansın tümü)"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đóng toàn bộ bảng (tất cả %lld tham chiếu)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭整个面板（全部 %lld 个引用）"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "關閉整個面板（全部 %lld 個參照）"
